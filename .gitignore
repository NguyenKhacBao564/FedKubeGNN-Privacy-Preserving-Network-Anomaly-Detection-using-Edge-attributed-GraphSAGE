# =====================================================
# IoT-23 FL+GNN — Giai đoạn 1
# =====================================================

# --- Dữ liệu thô & file trung gian ---
data/
checkpoints/
artifacts/*          # ignore mọi thứ TRONG artifacts/

# --- Ngoại lệ: track kết quả cuối cùng GĐ1 ---
!artifacts/phase1_results/
!artifacts/eda_summary.csv
artifacts/phase1_results/*   # re-ignore tất cả trong phase1_results/
# cho phép lại các file CSV + confusion matrix PNG:
!artifacts/phase1_results/results_summary.csv
!artifacts/phase1_results/phase_a_*.csv
!artifacts/phase1_results/phase_b_*.csv
!artifacts/phase1_results/checkpoints/
artifacts/phase1_results/checkpoints/*   # re-ignore nội dung checkpoints/
!artifacts/phase1_results/checkpoints/*.png  # cho phép PNG confusion matrix

# --- Artifact nhị phân ---
*.pt
*.pth
*.parquet
*.pkl
*.joblib
*.npy
*.npz

# --- Môi trường ảo ---
.venv/
venv/
env/

# --- Python cache ---
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo

# --- OS rác ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Log & file tạm ---
*.log
*.tmp
*.bak
nohup.out

# --- Secrets / Env ---
.env
.env.*
!.env.example

# --- Jupyter / Notebooks ---
.ipynb_checkpoints/

# --- Explicitly allowed files ---
!CLAUDE.md
!README.md